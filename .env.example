# CodeFox Environment Configuration
# To easily change the backend URL:
# 1. Rename this file from .env.example to .env
# 2. Change the VITE_API_URL value below to your live server's URL.

# For Local Development (default is already localhost:5000, so you can leave this blank locally if you wish)
VITE_API_URL=http://localhost:5000

# Example For Production (when you upload this to Vercel/Netlify, set this directly in their dashboard):
# VITE_API_URL=https://api.codefox.com
